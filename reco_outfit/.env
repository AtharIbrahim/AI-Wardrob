# Mistral AI Configuration
MISTRAL_API_KEY=Your_API_Key

# You can get your API key from: https://console.mistral.ai/
# Replace 'Your_API_Key' with your actual API key if this is not yours

# OpenWeather API Configuration
# Get your free API key from: https://openweathermap.org/api
# Replace YOUR_API_KEY_HERE with your actual API key
OPENWEATHER_API_KEY=Your_API_Key

# Alternative FREE Weather APIs (no registration required):
# 1. Open-Meteo (completely free, no API key needed): https://open-meteo.com/
# 2. WeatherAPI (free tier with 1M calls/month): https://www.weatherapi.com/
# 3. AccuWeather (free tier): https://developer.accuweather.com/

# WeatherAPI (free tier - 1M calls/month)
# Get your free API key from: https://www.weatherapi.com/signup.aspx
# WEATHERAPI_KEY=YOUR_WEATHERAPI_KEY_HERE

# Choose your preferred weather service:
# OPTIONS: openweather, open-meteo, weatherapi
# WEATHER_SERVICE=open-meteo
